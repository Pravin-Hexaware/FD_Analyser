# Azure OpenAI / Azure LLM settings
# Example values (replace with your own credentials)

# Full endpoint URL, e.g. https://<your-resource-name>.openai.azure.com
AZURE_ENDPOINT=

# Deployment name (model) configured in Azure OpenAI
MODEL_NAME=

# API version to use (match your Azure OpenAI deployment)
API_VERSION=2023-05-15

# API key for Azure OpenAI (often called subscription key)
AZURE_SUBSCRIPTION_KEY=
